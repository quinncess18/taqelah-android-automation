{
  "name": "taqelah-mobile-automation",
  "version": "1.0.0",
  "description": "Enterprise-grade Flutter mobile automation framework for Taqelah Boutique",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:login": "npx playwright test tests/specs/01_auth/01_functional.spec.js",
    "test:login:neg": "npx playwright test tests/specs/01_auth/02_negative.spec.js",
    "test:catalog": "npx playwright test tests/specs/02_catalog/01_landing.spec.js",
    "test:categories": "npx playwright test tests/specs/02_catalog/02_categories.spec.js",
    "test:nav": "npx playwright test tests/specs/03_nav/01_main_nav.spec.js",
    "test:gestures": "npx playwright test tests/specs/03_nav/02_gestures.spec.js",
    "test:webview": "npx playwright test tests/specs/03_nav/03_webview.spec.js",
    "test:dialogs": "npx playwright test tests/specs/03_nav/04_dialogs.spec.js",
    "test:form": "npx playwright test tests/specs/03_nav/05_form.spec.js",
    "test:permissions": "npx playwright test tests/specs/03_nav/06_permissions.spec.js",
    "test:notifications": "npx playwright test tests/specs/03_nav/07_notifications.spec.js",
    "test:tabs": "npx playwright test tests/specs/03_nav/08_tabs.spec.js",
    "test:camera": "npx playwright test tests/specs/03_nav/09_camera.spec.js",
    "test:location": "npx playwright test tests/specs/03_nav/10_location.spec.js",
    "test:darkmode": "npx playwright test tests/specs/03_nav/11_dark_mode.spec.js",
    "test:products": "npx playwright test tests/specs/04_products/01_product_detail_add.spec.js",
    "test:cart": "npx playwright test tests/specs/04_products/02_cart.spec.js",
    "appium:start": "npx appium --allow-insecure adb_shell"
  },
  "dependencies": {
    "webdriverio": "^8.36.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "appium": "^2.11.3",
    "appium-uiautomator2-driver": "^4.0.0",
    "io.appium.settings": "^7.1.0",
    "pngjs": "^7.0.0"
  },
  "keywords": [
    "playwright",
    "appium",
    "android",
    "flutter",
    "automation",
    "taqelah"
  ],
